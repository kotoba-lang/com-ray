// Ray clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace ray {

    entity Device {
        id: string @unique
        name: string
        vendor: string
        memoryGb: integer
        index: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Kernel {
        id: string @unique
        deviceId: string
        name: string
        gridDim: string
        blockDim: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity MemoryAlloc {
        id: string @unique
        deviceId: string
        sizeBytes: integer
        ptr: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity InferenceJob {
        id: string @unique
        modelRef: string
        deviceId: string
        status: string
        latencyMs: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Engine {
        id: string @unique
        name: string
        precision: string
        maxBatch: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Utilization {
        id: string @unique
        deviceId: string
        gpuPct: float
        memPct: float
        sampledAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
